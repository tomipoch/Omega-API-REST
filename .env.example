# Server
PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=omega_db

# Auth
JWT_SECRET=cambiar-en-produccion
JWT_REFRESH_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email
EMAIL_USER=
EMAIL_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS (CSV)
CORS_ORIGINS=http://localhost:5173

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# AI Provider (OpenAI-compatible: OpenAI, MiniMax, Kimi, GLM, etc.)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=15000