# Server
PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=omega_db

# Auth
JWT_SECRET=cambiar-en-produccion
JWT_REFRESH_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email
EMAIL_USER=
EMAIL_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS (CSV)
CORS_ORIGINS=http://localhost:5173

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5