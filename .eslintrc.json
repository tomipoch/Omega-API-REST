{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "extends": ["eslint:recommended", "plugin:node/recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-console": "warn",
    "consistent-return": "warn",
    "prefer-const": "warn",
    "no-var": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-await-in-loop": "off",
    "node/no-unsupported-features/es-syntax": ["error", { "version": ">=18" }],
    "node/no-unsupported-features/node-builtins": ["error", { "version": ">=18" }],
    "no-process-exit": "off",
    "node/no-unpublished-require": ["error", { "allowModules": ["supertest", "jest"] }]
  },
  "ignorePatterns": [
    "node_modules/",
    "uploads/",
    "coverage/",
    "*.log",
    "combined.log",
    "error.log",
    "omegadb.sql",
    "database/migrations/*.sql",
    "test/setup.js",
    "test/helpers/",
    "test/test_reservas.js",
    "test/test_reservas_simple.js",
    "database/migrations/runner.js",
    "scripts/migrations-status.js"
  ]
}
